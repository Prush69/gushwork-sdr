# ── Retell AI ──────────────────────────────────────────────
RETELL_API_KEY=your_retell_api_key
RETELL_AGENT_ID=your_retell_agent_id
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret

# ── Gemini (LLM) ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview

# ── Cal.com (Calendar) ───────────────────────────────────
CALCOM_API_KEY=your_calcom_api_key
CALCOM_EVENT_TYPE_ID=0

# ── CRM (HubSpot) — Optional ─────────────────────────────
HUBSPOT_API_KEY=
CRM_PROVIDER=hubspot

# ── Server ────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WEBHOOK_BASE_URL=https://your-app.onrender.com

# ── Pipeline Runtime Controls ─────────────────────────────
LLM_CONTEXT_MESSAGES=16
CALL_STATE_TTL_SECONDS=7200
AUDIT_QUERY_TIMEOUT_SECONDS=20
AUDIT_CACHE_TTL_SECONDS=3600
